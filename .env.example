# deep_think_mcp — example configuration
# Copy to .env and fill in your values, or export these in your shell / run.sh
#
# Three common setups are shown below. Uncomment the one that fits your environment.
# Model tiers (light/medium/heavy) are auto-assigned at startup by discovery
# benchmarking — you only need to override if you want specific models.

# ─────────────────────────────────────────────────────────────────────────────
# SETUP 1: Local Ollama only  (privacy-first, no cloud keys required)
# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# DEEP_THINK_DATA_POLICY=local      # hard-block any cloud provider
#
# Discovery runs at startup and auto-assigns tiers from whatever models
# are installed. Install models with: ollama pull phi4-mini llama3.1 qwen2.5-coder
# No API keys needed.

# ─────────────────────────────────────────────────────────────────────────────
# SETUP 2: GitHub Copilot API  (cloud, no local GPU required)
# ─────────────────────────────────────────────────────────────────────────────
# Requires GitHub Copilot subscription (Free/Pro/Business/Enterprise).
# run.sh automatically injects the OAuth token via `gh auth token` —
# no manual token setup needed if you have the `gh` CLI installed and logged in.
#
# Available models (all via api.githubcopilot.com):
#   GPT:    gpt-4o-mini, gpt-4.1, gpt-5.2, gpt-5.4
#   Claude: claude-sonnet-4.6, claude-opus-4.7, claude-opus-4.6
#   Codex:  gpt-5.2-codex, gpt-5.3-codex
#   Gemini: gemini-2.5-pro (if enabled by your org)
#
# Override defaults if desired:
# DEEP_THINK_COPILOT_LIGHT=gpt-4o-mini
# DEEP_THINK_COPILOT_MEDIUM=claude-sonnet-4.6
# DEEP_THINK_COPILOT_HEAVY=claude-opus-4.7
#
# No OLLAMA_BASE_URL needed — discovery is skipped when Ollama is not in use.

# ─────────────────────────────────────────────────────────────────────────────
# SETUP 3: Mixed — local Ollama for cheap passes, Copilot for synthesis
# (cost-optimised: run light/medium locally, heavy remotely)
# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
#
# DEEP_THINK_LIGHT_PROVIDER=ollama
# DEEP_THINK_MEDIUM_PROVIDER=ollama
# DEEP_THINK_HEAVY_PROVIDER=copilot
#
# DEEP_THINK_COPILOT_HEAVY=claude-opus-4.7
#
# Ollama model tiers are auto-discovered at startup. Override if needed:
# DEEP_THINK_MODEL_LIGHT=phi4-mini:latest
# DEEP_THINK_MODEL_MEDIUM=qwen3:8b
# DEEP_THINK_MODEL_HEAVY=llama3.1:8b

# ─────────────────────────────────────────────────────────────────────────────
# SETUP 4: Abliteration API  (optional cloud provider)
# ─────────────────────────────────────────────────────────────────────────────
# ABLITERATION_API_KEY=...
# ABLITERATION_BASE_URL=https://api.abliteration.ai/v1
# DEEP_THINK_ABLITERATION_LIGHT=gpt-4.1
# DEEP_THINK_ABLITERATION_MEDIUM=gpt-5.4
# DEEP_THINK_ABLITERATION_HEAVY=gpt-5.5

# ─────────────────────────────────────────────────────────────────────────────
# SETUP 4b: Private adversarial lane (challenger-only routing)
# ─────────────────────────────────────────────────────────────────────────────
# These knobs affect only task_class=adversarial. They do not change normal
# synthesis/default routing for other task classes.
#
# Choose lane provider: auto (default), ollama, or abliteration
# DEEP_THINK_PRIVATE_ADVERSARIAL_PROVIDER=auto
#
# Optional dedicated heretic endpoint/model (local-first private lane)
# DEEP_THINK_PRIVATE_ADVERSARIAL_OLLAMA_BASE_URL=http://localhost:11434
# DEEP_THINK_PRIVATE_ADVERSARIAL_HERETIC_MODEL=dolphin-mistral:latest
# DEEP_THINK_PRIVATE_ADVERSARIAL_HERETIC_LIGHT=dolphin-mistral:latest
# DEEP_THINK_PRIVATE_ADVERSARIAL_HERETIC_MEDIUM=dolphin-mistral:latest
# DEEP_THINK_PRIVATE_ADVERSARIAL_HERETIC_HEAVY=dolphin-mistral:latest
#
# Allow explicit fallback to Abliteration when local private lane is unavailable
# DEEP_THINK_PRIVATE_ADVERSARIAL_ALLOW_ABLITERATION=1
# DEEP_THINK_PRIVATE_ADVERSARIAL_ABLITERATION_MODEL=gpt-5.4
# DEEP_THINK_PRIVATE_ADVERSARIAL_ABLITERATION_LIGHT=gpt-4.1
# DEEP_THINK_PRIVATE_ADVERSARIAL_ABLITERATION_MEDIUM=gpt-5.4
# DEEP_THINK_PRIVATE_ADVERSARIAL_ABLITERATION_HEAVY=gpt-5.5

# ─────────────────────────────────────────────────────────────────────────────
# SETUP 5: Anthropic API  (direct Anthropic key, bypasses Copilot)
# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# DEEP_THINK_ANTHROPIC_LIGHT=claude-haiku-4-5
# DEEP_THINK_ANTHROPIC_MEDIUM=claude-sonnet-4-6
# DEEP_THINK_ANTHROPIC_HEAVY=claude-opus-4-7

# ─────────────────────────────────────────────────────────────────────────────
# GENERAL SETTINGS (apply to all setups)
# ─────────────────────────────────────────────────────────────────────────────

# Transport mode:
#   "stdio"           — for MCP clients (Claude Desktop, Copilot CLI) via run.sh
#   "streamable-http" — for HTTP consumers (DAMA NovaMcpClient, web clients) via run_http.sh
# DEEP_THINK_TRANSPORT=stdio

# HTTP server settings (only used when DEEP_THINK_TRANSPORT=streamable-http)
# DEEP_THINK_HOST=0.0.0.0
# DEEP_THINK_PORT=8080

# SQLite database path (default: ~/.deep_think/jobs.db)
# DEEP_THINK_DB=/path/to/jobs.db

# Max simultaneous reasoning jobs (default: 2)
# DEEP_THINK_MAX_CONCURRENCY=2

# Data policy — controls which providers can receive data
# "any"   = use any configured provider (default)
# "local" = Ollama only, never send to cloud (for sensitive investigations)
# "cloud" = cloud preferred, Ollama only for light tier
# DEEP_THINK_DATA_POLICY=any

# Qwen thinking mode — extended CoT is disabled for qwen* models by default
# DEEP_THINK_OLLAMA_THINK=false   # disable for all Ollama models
# DEEP_THINK_OLLAMA_THINK=true    # enable for all Ollama models

# ─────────────────────────────────────────────────────────────────────────────
# MQTT LOCAL-ONLY LLM ENFORCEMENT (Security hardening)
# ─────────────────────────────────────────────────────────────────────────────

# Force local-only models for MQTT operations (prevent cloud provider leakage)
# "1" = enforced; "0" = allow cloud providers
# DEEP_THINK_FORCE_LOCAL=1

# Strictest enforcement mode — fail hard on any cloud provider attempt
# "1" = OLLAMA_ONLY, no fallback to cloud; "0" = graceful degradation
# Implies DEEP_THINK_FORCE_LOCAL=1
# OLLAMA_ONLY_MODE=0

# Ollama timeout fallback — if an Ollama call times out, retry on cloud.
# Useful when a large local model (e.g. qwen3.5:27b) exceeds the benchmarked
# timeout on a long multi-pass job. Copilot is tried first, then Anthropic.
# Only applies when the primary provider for a tier is Ollama.
# DEEP_THINK_OLLAMA_TIMEOUT_FALLBACK=true

# Perspective cache TTL — how long fan-out perspective outputs are cached (hours).
# Cached outputs enable: resume-on-failure (Ollama timeout = free retry),
# repeatability (re-run synthesis with same perspectives, different prompt),
# and debugging (inspect each perspective independently in the SQLite DB).
# DAMA analog: pheromone evaporation — stale signals fade after TTL.
# Default: 24 hours. Set to 0 to disable caching.
# DEEP_THINK_CACHE_TTL_HOURS=24

# Logging level
# LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# GROUND TRUTH VALIDATION: Nova/MQTT Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Provider type for ground truth validation:
#   "nova"   — Use Great Library (Nova) for claim validation
#   "mqtt"   — Use DAMA phone MQTT telemetry directly
#   "none"   — Disable ground truth validation
# GROUND_TRUTH_PROVIDER=nova

# Nova/Great Library Configuration
# NOVA_BASE_URL=http://localhost:30850  # k3s Oxalis endpoint (default)
# NOVA_TOKEN=nova-xxxxxxxxxxxxxxxxxxxxxxxx   # MCP API token (required for k3s)
# NOVA_TOTP_SEED=YOUR_BASE32_TOTP_SEED             # Time-based OTP seed

# Nova timeout configuration (seconds)
# NOVA_MCP_HTTP_CONNECT_TIMEOUT=10
# NOVA_MCP_HTTP_READ_TIMEOUT=20
# NOVA_MCP_DEEP_THINK_READ_TIMEOUT=180
# NOVA_MCP_SYNTHESIZE_READ_TIMEOUT=45

# MQTT Broker Configuration (for ground truth validation)
# MQTT_HOST=localhost  # MQTT broker hostname
# MQTT_PORT=1883                    # MQTT broker port (1883=plain, 8883=TLS)
# MQTT_USERNAME=dama               # MQTT authentication username
# MQTT_PASSWORD=xxxxxxxxxxxxx      # MQTT authentication password (keep secret!)
# MQTT_USE_TLS=false               # Enable TLS/SSL for MQTT (recommended for production)

# MQTT message cache and device presence tracking
# MQTT_CACHE_TTL_SECONDS=30        # Seconds before sensor data is considered stale
# MQTT_CACHE_DB=~/.deep_think/mqtt_cache.db  # Persist cache to disk

# ─────────────────────────────────────────────────────────────────────────────
# MQTT FINDINGS PUBLISHER Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Enable/disable findings publisher
# PUBLISHER_ENABLE=true

# Batch settings for findings publisher
# PUBLISHER_BATCH_SIZE=10           # Max findings per batch before publishing
# PUBLISHER_BATCH_TIMEOUT_MS=5000   # Milliseconds to wait before publishing partial batch
# PUBLISHER_MAX_RETRIES=8           # Max retry attempts before persisting to SQLite
