# deep_think_mcp — example configuration
# Copy to .env and fill in your values, or export these in your shell / run.sh
#
# Three common setups are shown below. Uncomment the one that fits your environment.
# Model tiers (light/medium/heavy) are auto-assigned at startup by discovery
# benchmarking — you only need to override if you want specific models.

# ─────────────────────────────────────────────────────────────────────────────
# SETUP 1: Local Ollama only  (privacy-first, no cloud keys required)
# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# DEEP_THINK_DATA_POLICY=local      # hard-block any cloud provider
#
# Discovery runs at startup and auto-assigns tiers from whatever models
# are installed. Install models with: ollama pull phi4-mini llama3.1 qwen2.5-coder
# No API keys needed.

# ─────────────────────────────────────────────────────────────────────────────
# SETUP 2: GitHub Models API only  (cloud, no local GPU required)
# ─────────────────────────────────────────────────────────────────────────────
# Requires a fine-grained personal access token with "models:read" permission.
# Create one at: https://github.com/settings/personal-access-tokens/new
# (Choose "Fine-grained token" → Repository access: None → Permissions → Account:
#  Models → Read)
#
# NOTE: Classic OAuth tokens from `gh auth token` do NOT have models:read scope.
#       You must create a separate fine-grained PAT.
#
# GITHUB_MODELS_TOKEN=github_pat_...
#
# Available models (all via models.github.ai):
#   OpenAI: openai/gpt-5, openai/gpt-4.1, openai/gpt-4.1-mini
#   Reasoning: openai/o3, openai/o4-mini, deepseek/deepseek-r1
#   Code: mistral-ai/codestral-2501
#   Meta: meta/llama-4-maverick-17b-128e-instruct-fp8, meta/llama-3.3-70b-instruct
#
# DEEP_THINK_COPILOT_LIGHT=openai/gpt-4.1-mini
# DEEP_THINK_COPILOT_MEDIUM=openai/gpt-4.1
# DEEP_THINK_COPILOT_HEAVY=openai/gpt-5
#
# No OLLAMA_BASE_URL needed — discovery is skipped when Ollama is not in use.

# ─────────────────────────────────────────────────────────────────────────────
# SETUP 3: Mixed — local Ollama for cheap passes, GitHub Models for synthesis
# (cost-optimised: run light/medium locally, heavy remotely)
# ─────────────────────────────────────────────────────────────────────────────
# GITHUB_MODELS_TOKEN=github_pat_...   # fine-grained PAT with models:read
# OLLAMA_BASE_URL=http://localhost:11434
#
# DEEP_THINK_LIGHT_PROVIDER=ollama
# DEEP_THINK_MEDIUM_PROVIDER=ollama
# DEEP_THINK_HEAVY_PROVIDER=copilot
#
# DEEP_THINK_COPILOT_HEAVY=openai/gpt-5
#
# Ollama model tiers are auto-discovered at startup. Override if needed:
# DEEP_THINK_MODEL_LIGHT=phi4-mini:latest
# DEEP_THINK_MODEL_MEDIUM=llama3.1:8b

# ─────────────────────────────────────────────────────────────────────────────
# SETUP 4: Anthropic API  (use this for Claude models)
# ─────────────────────────────────────────────────────────────────────────────
# Claude is NOT available via GitHub Models — Anthropic API key required.
# ANTHROPIC_API_KEY=sk-ant-...
# DEEP_THINK_ANTHROPIC_LIGHT=claude-haiku-4-5
# DEEP_THINK_ANTHROPIC_MEDIUM=claude-sonnet-4-6
# DEEP_THINK_ANTHROPIC_HEAVY=claude-opus-4-7

# ─────────────────────────────────────────────────────────────────────────────
# GENERAL SETTINGS (apply to all setups)
# ─────────────────────────────────────────────────────────────────────────────

# Transport: "stdio" for MCP clients (Claude Desktop, Copilot CLI)
#            "streamable-http" for HTTP server mode (default)
# DEEP_THINK_TRANSPORT=stdio

# SQLite database path (default: ~/.deep_think/jobs.db)
# DEEP_THINK_DB=/path/to/jobs.db

# Max simultaneous reasoning jobs (default: 2)
# DEEP_THINK_MAX_CONCURRENCY=2

# Data policy — controls which providers can receive data
# "any"   = use any configured provider (default)
# "local" = Ollama only, never send to cloud (for sensitive investigations)
# "cloud" = cloud preferred, Ollama only for light tier
# DEEP_THINK_DATA_POLICY=any

# Qwen thinking mode — extended CoT is disabled for qwen* models by default
# DEEP_THINK_OLLAMA_THINK=false   # disable for all Ollama models
# DEEP_THINK_OLLAMA_THINK=true    # enable for all Ollama models

# Logging level
# LOG_LEVEL=INFO
